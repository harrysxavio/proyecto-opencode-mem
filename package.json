{
  "name": "proyecto-opencode-mem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Runtime Kit for OpenCode & Codex: portable Manager contracts, SDD pipeline, memory governance, skills, installers and profiles.",
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "validate": "node scripts/validate.mjs",
    "sanitize:check": "node scripts/sanitize-check.mjs",
    "docs:check": "node scripts/docs-check.mjs",
    "test": "node --test",
    "test:shared": "node scripts/run-tests.mjs tests",
    "test:codex": "node scripts/run-tests.mjs codex/tests",
    "test:opencode": "node scripts/run-tests.mjs opencode/tests",
    "test:all": "node scripts/validate.mjs && node scripts/sanitize-check.mjs && node scripts/docs-check.mjs && node scripts/run-tests.mjs",
    "install:dry-run": "node scripts/install.mjs --dry-run",
    "install:temp": "node scripts/install-temp.mjs",
    "backup:plan": "node scripts/backup.mjs --plan",
    "rollback:plan": "node scripts/rollback.mjs --plan",
    "export:inventory": "node scripts/export-inventory.mjs",
    "codex:install:dry-run": "node codex/scripts/install-overlay.mjs --dry-run",
    "codex:install": "node codex/scripts/install-overlay.mjs",
    "codex:doctor": "node codex/scripts/doctor.mjs",
    "codex:rollback:dry-run": "node codex/scripts/rollback-overlay.mjs --dry-run",
    "codex:rollback": "node codex/scripts/rollback-overlay.mjs",
    "codex:memory:lint": "node codex/scripts/memory-lint.mjs",
    "codex:context:check": "node codex/scripts/context-pack-check.mjs",
    "codex:tokens:report": "node codex/scripts/token-budget-report.mjs",
    "codex:registry": "node codex/scripts/skill-registry-generate.mjs",
    "opencode:install:dry-run": "node opencode/scripts/install-overlay.mjs --dry-run",
    "opencode:install": "node opencode/scripts/install-overlay.mjs",
    "opencode:doctor": "node opencode/scripts/doctor.mjs",
    "opencode:rollback:dry-run": "node opencode/scripts/rollback-overlay.mjs --dry-run",
    "opencode:rollback": "node opencode/scripts/rollback-overlay.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
